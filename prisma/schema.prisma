generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum StockMovementType {
  INBOUND
  OUTBOUND
  ADJUSTMENT
}

enum DocumentStatus {
  DRAFT
  SENT
  APPROVED
  REJECTED
  CONFIRMED
  CONVERTED
  PARTIAL
  FULFILLED
  CLOSED
  CANCELLED
  PARTIALLY_RECEIVED
  RECEIVED
}

enum ClientType {
  INDIVIDUAL
  INSTITUTION
}

enum NotificationSeverity {
  LOW
  MEDIUM
  HIGH
}

enum SubscriptionPlan {
  FREE
  STARTER
  GROWTH
  ENTERPRISE
}

enum SubscriptionStatus {
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELED
}

enum BillingEventType {
  CHECKOUT_COMPLETED
  SUBSCRIPTION_UPDATED
  SUBSCRIPTION_CANCELED
  INVOICE_PAID
  INVOICE_PAYMENT_FAILED
}

enum BillingEventStatus {
  INFO
  SUCCEEDED
  FAILED
}

enum UserKind {
  MASTER
  TENANT_ADMIN
  TENANT_MEMBER
}

enum LlmProvider {
  OPENAI
  OPENAI_COMPATIBLE
}

enum LlmAccessMode {
  SHARED
  BYOK
}

enum IngestionSource {
  WEB_UPLOAD
  COPILOT_CHAT
  TELEGRAM
  WHATSAPP
  API
}

enum IngestionStatus {
  RECEIVED
  ANALYZED
  READY_APPLY
  APPLIED
  NEEDS_REVIEW
  FAILED
}

enum IngestionDocType {
  UNKNOWN
  PRODUCTS
  CLIENTS
  SUPPLIERS
  SALES_QUOTE
  SALES_ORDER
  PURCHASE_ORDER
  GOODS_RECEIPT
  STOCK_ADJUSTMENT
}

enum IngestionActionType {
  UPSERT_PRODUCT
  UPSERT_CLIENT
  UPSERT_SUPPLIER
  CREATE_SALES_QUOTE
  CREATE_SALES_ORDER
  CREATE_PURCHASE_ORDER
  CREATE_GOODS_RECEIPT
  ADJUST_STOCK
}

enum IngestionActionStatus {
  PLANNED
  APPLIED
  SKIPPED
  FAILED
}

enum ProductUnitMode {
  GLOBAL
  PER_PRODUCT
}

model Company {
  id              String                  @id @default(uuid())
  name            String
  domain          String?
  ownerUserId     String?                 @unique
  currencyCode    String                  @default("USD")
  productUnitMode ProductUnitMode         @default(PER_PRODUCT)
  defaultProductUnit String               @default("EA")
  locale          String                  @default("en-US")
  timezone        String                  @default("UTC")
  createdAt       DateTime                @default(now())
  updatedAt       DateTime                @updatedAt
  users           User[]                  @relation("CompanyUsers")
  owner           User?                   @relation("CompanyOwner", fields: [ownerUserId], references: [id])
  roles           Role[]
  roleAssignments UserRole[]
  rolePermissions RolePermission[]
  permissions     Permission[]
  products        Product[]
  categories      ProductCategory[]
  customFields    CustomFieldDefinition[]
  customValues    CustomFieldValue[]
  warehouses      Warehouse[]
  stockMovements  StockMovement[]
  clients         Client[]
  suppliers       Supplier[]
  salesQuotes     SalesQuote[]
  salesOrders     SalesOrder[]
  purchaseOrders  PurchaseOrder[]
  goodsReceipts   GoodsReceipt[]
  auditLogs       AuditLog[]
  notifications   Notification[]
  llmConfig       CompanyLlmConfig?
  messagingConfig CompanyMessagingConfig?
  billingEvents   BillingEvent[]
  taxRules        TaxRule[]
  stockRule       StockRule?
  subscription    TenantSubscription?
  liveWorkspace   CompanyWorkspace?       @relation("LiveWorkspace")
  simulationWorkspace CompanyWorkspace?   @relation("SimulationWorkspace")
  ingestionJobs   IngestionJob[]
  ingestionActions IngestionAction[]

}

model CompanyMessagingConfig {
  id                          String   @id @default(uuid())
  companyId                   String   @unique
  company                     Company  @relation(fields: [companyId], references: [id])
  whatsappEnabled             Boolean  @default(false)
  whatsappPhoneNumber         String?
  whatsappBusinessAccountId   String?
  whatsappAccessTokenEncrypted String?
  whatsappAccessTokenHint     String?
  telegramEnabled             Boolean  @default(false)
  telegramBotUsername         String?
  telegramBotTokenEncrypted   String?
  telegramBotTokenHint        String?
  createdAt                   DateTime @default(now())
  updatedAt                   DateTime @updatedAt

  @@index([companyId])
}

model CompanyWorkspace {
  id                  String   @id @default(uuid())
  companyId           String   @unique
  simulationCompanyId String   @unique
  company             Company  @relation("LiveWorkspace", fields: [companyId], references: [id])
  simulationCompany   Company  @relation("SimulationWorkspace", fields: [simulationCompanyId], references: [id])
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@index([companyId])
  @@index([simulationCompanyId])
}

model CompanyLlmConfig {
  id              String      @id @default(uuid())
  companyId       String      @unique
  company         Company     @relation(fields: [companyId], references: [id])
  accessMode      LlmAccessMode @default(SHARED)
  provider        LlmProvider @default(OPENAI)
  baseUrl         String?
  encryptedApiKey String?
  keyHint         String?
  defaultModel    String      @default("gpt-4o-mini")
  isEnabled       Boolean     @default(false)
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
}

model User {
  id              String       @id @default(uuid())
  companyId       String
  company         Company      @relation("CompanyUsers", fields: [companyId], references: [id])
  kind            UserKind     @default(TENANT_MEMBER)
  ownedCompany    Company?     @relation("CompanyOwner")
  email           String       @unique
  name            String
  passwordHash    String
  isActive        Boolean      @default(true)
  lastLoginAt     DateTime?
  roles           UserRole[]
  auditLogs       AuditLog[]
  ingestionJobs   IngestionJob[] @relation("IngestionCreatedBy")
  quotesCreated   SalesQuote[]
  ordersCreated   SalesOrder[] @relation("OrderCreatedBy")
  ordersApproved  SalesOrder[] @relation("OrderApprovedBy")
  ordersConfirmed SalesOrder[] @relation("OrderConfirmedBy")
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  @@index([companyId])
}

model Role {
  id          String           @id @default(uuid())
  companyId   String
  company     Company          @relation(fields: [companyId], references: [id])
  name        String
  description String?
  users       UserRole[]
  permissions RolePermission[]
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@unique([companyId, name])
  @@index([companyId])
}

model Permission {
  id          String           @id @default(uuid())
  companyId   String
  company     Company          @relation(fields: [companyId], references: [id])
  code        String
  description String?
  roles       RolePermission[]
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@unique([companyId, code])
  @@index([companyId])
}

model RolePermission {
  id           String     @id @default(uuid())
  roleId       String
  permissionId String
  role         Role       @relation(fields: [roleId], references: [id])
  permission   Permission @relation(fields: [permissionId], references: [id])
  companyId    String
  company      Company    @relation(fields: [companyId], references: [id])
  createdAt    DateTime   @default(now())

  @@unique([roleId, permissionId])
  @@index([companyId])
}

model UserRole {
  id        String   @id @default(uuid())
  userId    String
  roleId    String
  companyId String
  company   Company  @relation(fields: [companyId], references: [id])
  user      User     @relation(fields: [userId], references: [id])
  role      Role     @relation(fields: [roleId], references: [id])
  createdAt DateTime @default(now())

  @@unique([userId, roleId])
  @@index([companyId])
}

model ProductCategory {
  id          String    @id @default(uuid())
  companyId   String
  company     Company   @relation(fields: [companyId], references: [id])
  name        String
  description String?
  products    Product[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([companyId, name])
  @@index([companyId])
}

model Product {
  id                String              @id @default(uuid())
  companyId         String
  company           Company             @relation(fields: [companyId], references: [id])
  sku               String
  name              String
  description       String?
  categoryId        String?
  category          ProductCategory?    @relation(fields: [categoryId], references: [id])
  unitPrice         Decimal             @db.Decimal(12, 2)
  unitOfMeasure     String              @default("EA")
  isActive          Boolean             @default(true)
  customValues      CustomFieldValue[]
  stockMovements    StockMovement[]
  quoteLines        SalesQuoteLine[]
  salesOrderLines   SalesOrderLine[]
  purchaseLines     PurchaseOrderLine[]
  receiptLines      GoodsReceiptLine[]
  lowStockThreshold Decimal?            @db.Decimal(12, 2)
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt

  @@unique([companyId, sku])
  @@index([companyId])
}

model CustomFieldDefinition {
  id         String             @id @default(uuid())
  companyId  String
  company    Company            @relation(fields: [companyId], references: [id])
  entityType String
  fieldKey   String
  label      String
  fieldType  String
  isRequired Boolean            @default(false)
  createdAt  DateTime           @default(now())
  updatedAt  DateTime           @updatedAt
  values     CustomFieldValue[]

  @@unique([companyId, entityType, fieldKey])
  @@index([companyId])
}

model CustomFieldValue {
  id         String                @id @default(uuid())
  companyId  String
  company    Company               @relation(fields: [companyId], references: [id])
  recordId   String
  entityType String
  fieldId    String
  definition CustomFieldDefinition @relation(fields: [fieldId], references: [id])
  productId  String?
  product    Product?              @relation(fields: [productId], references: [id])
  value      String
  createdAt  DateTime              @default(now())
  updatedAt  DateTime              @updatedAt

  @@index([companyId])
  @@index([recordId])
  @@index([productId])
}

model Warehouse {
  id              String             @id @default(uuid())
  companyId       String
  company         Company            @relation(fields: [companyId], references: [id])
  name            String
  location        String?
  stock           StockMovement[]
  goodsReceipts   GoodsReceipt[]
  receiptLines    GoodsReceiptLine[]
  quoteLines      SalesQuoteLine[]
  salesOrderLines SalesOrderLine[]
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  @@unique([companyId, name])
  @@index([companyId])
}

model StockMovement {
  id           String            @id @default(uuid())
  companyId    String
  company      Company           @relation(fields: [companyId], references: [id])
  productId    String
  product      Product           @relation(fields: [productId], references: [id])
  warehouseId  String
  warehouse    Warehouse         @relation(fields: [warehouseId], references: [id])
  movementType StockMovementType
  quantity     Decimal           @db.Decimal(12, 2)
  reference    String?
  movementDate DateTime          @default(now())
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  @@index([companyId])
  @@index([productId, warehouseId])
  @@index([movementDate])
}

model Client {
  id          String       @id @default(uuid())
  companyId   String
  company     Company      @relation(fields: [companyId], references: [id])
  name        String
  email       String?
  phone       String?
  address     String?
  clientType  ClientType   @default(INSTITUTION)
  salesQuotes SalesQuote[]
  salesOrders SalesOrder[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@unique([companyId, name])
  @@index([companyId])
  @@index([companyId, clientType])
}

model Supplier {
  id             String          @id @default(uuid())
  companyId      String
  company        Company         @relation(fields: [companyId], references: [id])
  name           String
  email          String?
  phone          String?
  address        String?
  purchaseOrders PurchaseOrder[]
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  @@unique([companyId, name])
  @@index([companyId])
}

model SalesQuote {
  id             String              @id @default(uuid())
  companyId      String
  company        Company             @relation(fields: [companyId], references: [id])
  clientId       String
  client         Client              @relation(fields: [clientId], references: [id])
  quoteNumber    Int
  quoteDate      DateTime            @default(now())
  validUntil     DateTime?
  status         DocumentStatus      @default(DRAFT)
  subtotalAmount Decimal             @db.Decimal(14, 2)
  taxAmount      Decimal             @db.Decimal(14, 2)
  totalAmount    Decimal             @db.Decimal(14, 2)
  notes          String?
  lines          SalesQuoteLine[]
  taxLines       SalesQuoteTaxLine[]
  convertedOrder SalesOrder?         @relation("QuoteConversion")
  createdById    String?
  createdBy      User?               @relation(fields: [createdById], references: [id])
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt

  @@unique([companyId, quoteNumber])
  @@index([companyId])
  @@index([quoteDate])
  @@index([companyId, quoteDate, status])
  @@index([companyId, status, validUntil])
}

model SalesQuoteLine {
  id           String     @id @default(uuid())
  salesQuoteId String
  salesQuote   SalesQuote @relation(fields: [salesQuoteId], references: [id])
  productId    String
  product      Product    @relation(fields: [productId], references: [id])
  warehouseId  String?
  warehouse    Warehouse? @relation(fields: [warehouseId], references: [id])
  description  String?
  quantity     Decimal    @db.Decimal(12, 2)
  unitPrice    Decimal    @db.Decimal(12, 2)
  lineTotal    Decimal    @db.Decimal(14, 2)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@index([warehouseId])
}

model SalesQuoteTaxLine {
  id           String     @id @default(uuid())
  salesQuoteId String
  salesQuote   SalesQuote @relation(fields: [salesQuoteId], references: [id])
  label        String
  taxCode      String?
  rate         Decimal    @db.Decimal(6, 3)
  baseAmount   Decimal    @db.Decimal(14, 2)
  taxAmount    Decimal    @db.Decimal(14, 2)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@index([salesQuoteId])
}

model SalesOrder {
  id             String              @id @default(uuid())
  companyId      String
  company        Company             @relation(fields: [companyId], references: [id])
  clientId       String
  client         Client              @relation(fields: [clientId], references: [id])
  salesQuoteId   String?             @unique
  salesQuote     SalesQuote?         @relation("QuoteConversion", fields: [salesQuoteId], references: [id])
  orderNumber    Int
  orderDate      DateTime            @default(now())
  status         DocumentStatus      @default(DRAFT)
  subtotalAmount Decimal             @db.Decimal(14, 2)
  taxAmount      Decimal             @db.Decimal(14, 2)
  totalAmount    Decimal             @db.Decimal(14, 2)
  notes          String?
  lines          SalesOrderLine[]
  taxLines       SalesOrderTaxLine[]
  createdById    String?
  createdBy      User?               @relation("OrderCreatedBy", fields: [createdById], references: [id])
  approvedById   String?
  approvedBy     User?               @relation("OrderApprovedBy", fields: [approvedById], references: [id])
  approvedAt     DateTime?
  confirmedById  String?
  confirmedBy    User?               @relation("OrderConfirmedBy", fields: [confirmedById], references: [id])
  confirmedAt    DateTime?
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt

  @@unique([companyId, orderNumber])
  @@index([companyId])
  @@index([companyId, status])
  @@index([orderDate])
  @@index([companyId, status, orderDate])
}

model SalesOrderLine {
  id           String     @id @default(uuid())
  salesOrderId String
  salesOrder   SalesOrder @relation(fields: [salesOrderId], references: [id])
  productId    String
  product      Product    @relation(fields: [productId], references: [id])
  warehouseId  String
  warehouse    Warehouse  @relation(fields: [warehouseId], references: [id])
  description  String?
  quantity     Decimal    @db.Decimal(12, 2)
  unitPrice    Decimal    @db.Decimal(12, 2)
  lineTotal    Decimal    @db.Decimal(14, 2)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@index([warehouseId])
  @@index([productId])
}

model SalesOrderTaxLine {
  id           String     @id @default(uuid())
  salesOrderId String
  salesOrder   SalesOrder @relation(fields: [salesOrderId], references: [id])
  label        String
  taxCode      String?
  rate         Decimal    @db.Decimal(6, 3)
  baseAmount   Decimal    @db.Decimal(14, 2)
  taxAmount    Decimal    @db.Decimal(14, 2)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@index([salesOrderId])
}

model PurchaseOrder {
  id             String                 @id @default(uuid())
  companyId      String
  company        Company                @relation(fields: [companyId], references: [id])
  supplierId     String
  supplier       Supplier               @relation(fields: [supplierId], references: [id])
  poNumber       Int
  orderDate      DateTime               @default(now())
  expectedDate   DateTime?
  status         DocumentStatus         @default(DRAFT)
  subtotalAmount Decimal                @db.Decimal(14, 2)
  taxAmount      Decimal                @db.Decimal(14, 2)
  totalAmount    Decimal                @db.Decimal(14, 2)
  notes          String?
  lines          PurchaseOrderLine[]
  taxLines       PurchaseOrderTaxLine[]
  goodsReceipts  GoodsReceipt[]
  createdAt      DateTime               @default(now())
  updatedAt      DateTime               @updatedAt

  @@index([companyId])
  @@index([orderDate])
  @@index([companyId, poNumber])
  @@index([companyId, status, orderDate])
  @@index([companyId, status, expectedDate])
}

model PurchaseOrderLine {
  id                String             @id @default(uuid())
  purchaseOrderId   String
  purchaseOrder     PurchaseOrder      @relation(fields: [purchaseOrderId], references: [id])
  productId         String
  product           Product            @relation(fields: [productId], references: [id])
  quantity          Decimal            @db.Decimal(12, 2)
  unitPrice         Decimal            @db.Decimal(12, 2)
  lineTotal         Decimal            @db.Decimal(14, 2)
  goodsReceiptLines GoodsReceiptLine[]
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
}

model PurchaseOrderTaxLine {
  id              String        @id @default(uuid())
  purchaseOrderId String
  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id])
  label           String
  taxCode         String?
  rate            Decimal       @db.Decimal(6, 3)
  baseAmount      Decimal       @db.Decimal(14, 2)
  taxAmount       Decimal       @db.Decimal(14, 2)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([purchaseOrderId])
}

model GoodsReceipt {
  id              String             @id @default(uuid())
  companyId       String
  company         Company            @relation(fields: [companyId], references: [id])
  purchaseOrderId String?
  purchaseOrder   PurchaseOrder?     @relation(fields: [purchaseOrderId], references: [id])
  warehouseId     String
  warehouse       Warehouse          @relation(fields: [warehouseId], references: [id])
  receiptNumber   Int
  receivedDate    DateTime           @default(now())
  status          DocumentStatus     @default(PARTIAL)
  notes           String?
  lines           GoodsReceiptLine[]
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  @@index([companyId])
  @@index([receivedDate])
  @@index([companyId, receiptNumber])
  @@index([companyId, status, receivedDate])
}

model GoodsReceiptLine {
  id                  String            @id @default(uuid())
  goodsReceiptId      String
  goodsReceipt        GoodsReceipt      @relation(fields: [goodsReceiptId], references: [id])
  purchaseOrderLineId String
  purchaseOrderLine   PurchaseOrderLine @relation(fields: [purchaseOrderLineId], references: [id])
  productId           String
  product             Product           @relation(fields: [productId], references: [id])
  quantity            Decimal           @db.Decimal(12, 2)
  unitPrice           Decimal           @db.Decimal(12, 2)
  lineTotal           Decimal           @db.Decimal(14, 2)
  warehouseId         String
  warehouse           Warehouse         @relation(fields: [warehouseId], references: [id])
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt
}

model AuditLog {
  id        String   @id @default(uuid())
  companyId String
  company   Company  @relation(fields: [companyId], references: [id])
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
  action    String
  entity    String
  entityId  String
  metadata  Json?
  createdAt DateTime @default(now())

  @@index([companyId])
  @@index([entity])
  @@index([companyId, createdAt])
  @@index([companyId, entity, createdAt])
}

model TaxRule {
  id         String   @id @default(uuid())
  companyId  String
  company    Company  @relation(fields: [companyId], references: [id])
  code       String
  label      String
  rate       Decimal  @db.Decimal(6, 3)
  isDefault  Boolean  @default(false)
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([companyId, code])
  @@index([companyId])
}

model StockRule {
  id                       String   @id @default(uuid())
  companyId                String   @unique
  company                  Company  @relation(fields: [companyId], references: [id])
  allowNegativeStock       Boolean  @default(false)
  defaultLowStockThreshold Decimal? @db.Decimal(12, 2)
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt
}

model Notification {
  id         String               @id @default(uuid())
  companyId  String
  company    Company              @relation(fields: [companyId], references: [id])
  category   String
  title      String
  message    String
  severity   NotificationSeverity @default(LOW)
  href       String?
  fingerprint String
  metadata   Json?
  readAt     DateTime?
  createdAt  DateTime             @default(now())
  updatedAt  DateTime             @updatedAt

  @@unique([companyId, fingerprint])
  @@index([companyId, createdAt])
  @@index([companyId, readAt])
}

model TenantSubscription {
  id           String             @id @default(uuid())
  companyId    String             @unique
  company      Company            @relation(fields: [companyId], references: [id])
  plan         SubscriptionPlan   @default(FREE)
  status       SubscriptionStatus @default(TRIALING)
  seatLimit    Int                @default(3)
  billingEmail String?
  stripeCustomerId     String?    @unique
  stripeSubscriptionId String?    @unique
  startsAt     DateTime           @default(now())
  renewsAt     DateTime?
  canceledAt   DateTime?
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt

  @@index([status])
  @@index([plan])
}

model BillingEvent {
  id                   String             @id @default(uuid())
  companyId            String
  company              Company            @relation(fields: [companyId], references: [id])
  stripeEventId        String?            @unique
  stripeCustomerId     String?
  stripeSubscriptionId String?
  stripeInvoiceId      String?
  type                 BillingEventType
  status               BillingEventStatus @default(INFO)
  plan                 SubscriptionPlan?
  amount               Decimal?           @db.Decimal(14, 2)
  currencyCode         String?
  occurredAt           DateTime
  metadata             Json?
  createdAt            DateTime           @default(now())

  @@index([companyId, occurredAt])
  @@index([type, occurredAt])
  @@index([status, occurredAt])
  @@index([stripeSubscriptionId])
  @@index([stripeCustomerId])
}

model IngestionJob {
  id              String           @id @default(uuid())
  companyId       String
  company         Company          @relation(fields: [companyId], references: [id])
  createdByUserId String?
  createdByUser   User?            @relation("IngestionCreatedBy", fields: [createdByUserId], references: [id])
  source          IngestionSource
  status          IngestionStatus  @default(RECEIVED)
  docType         IngestionDocType @default(UNKNOWN)
  fileName        String?
  mimeType        String?
  fileSizeBytes   Int?
  rawText         String?
  extractedJson   Json?
  analysis        Json?
  errorMessage    String?
  receivedAt      DateTime         @default(now())
  analyzedAt      DateTime?
  appliedAt       DateTime?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  actions         IngestionAction[]

  @@index([companyId, createdAt])
  @@index([companyId, status])
  @@index([companyId, docType, createdAt])
}

model IngestionAction {
  id           String                @id @default(uuid())
  jobId        String
  job          IngestionJob          @relation(fields: [jobId], references: [id])
  companyId    String
  company      Company               @relation(fields: [companyId], references: [id])
  type         IngestionActionType
  status       IngestionActionStatus @default(PLANNED)
  payload      Json
  result       Json?
  errorMessage String?
  createdAt    DateTime              @default(now())
  updatedAt    DateTime              @updatedAt

  @@index([jobId, status])
  @@index([companyId, type, createdAt])
}
