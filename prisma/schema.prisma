generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum StockMovementType {
  INBOUND
  OUTBOUND
  ADJUSTMENT
}

enum DocumentStatus {
  DRAFT
  SENT
  APPROVED
  REJECTED
  CONFIRMED
  CONVERTED
  PARTIAL
  FULFILLED
  CLOSED
  CANCELLED
  PARTIALLY_RECEIVED
  RECEIVED
}

enum ClientType {
  INDIVIDUAL
  INSTITUTION
}

model Company {
  id              String                  @id @default(uuid())
  name            String
  domain          String?
  createdAt       DateTime                @default(now())
  updatedAt       DateTime                @updatedAt
  users           User[]
  roles           Role[]
  roleAssignments UserRole[]
  rolePermissions RolePermission[]
  permissions     Permission[]
  products        Product[]
  categories      ProductCategory[]
  customFields    CustomFieldDefinition[]
  customValues    CustomFieldValue[]
  warehouses      Warehouse[]
  stockMovements  StockMovement[]
  clients         Client[]
  suppliers       Supplier[]
  salesQuotes     SalesQuote[]
  salesOrders     SalesOrder[]
  purchaseOrders  PurchaseOrder[]
  goodsReceipts   GoodsReceipt[]
  auditLogs       AuditLog[]
}

model User {
  id              String       @id @default(uuid())
  companyId       String
  company         Company      @relation(fields: [companyId], references: [id])
  email           String       @unique
  name            String
  passwordHash    String
  isActive        Boolean      @default(true)
  lastLoginAt     DateTime?
  roles           UserRole[]
  auditLogs       AuditLog[]
  quotesCreated   SalesQuote[]
  ordersCreated   SalesOrder[] @relation("OrderCreatedBy")
  ordersApproved  SalesOrder[] @relation("OrderApprovedBy")
  ordersConfirmed SalesOrder[] @relation("OrderConfirmedBy")
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  @@index([companyId])
}

model Role {
  id          String           @id @default(uuid())
  companyId   String
  company     Company          @relation(fields: [companyId], references: [id])
  name        String
  description String?
  users       UserRole[]
  permissions RolePermission[]
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@unique([companyId, name])
  @@index([companyId])
}

model Permission {
  id          String           @id @default(uuid())
  companyId   String
  company     Company          @relation(fields: [companyId], references: [id])
  code        String
  description String?
  roles       RolePermission[]
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@unique([companyId, code])
  @@index([companyId])
}

model RolePermission {
  id           String     @id @default(uuid())
  roleId       String
  permissionId String
  role         Role       @relation(fields: [roleId], references: [id])
  permission   Permission @relation(fields: [permissionId], references: [id])
  companyId    String
  company      Company    @relation(fields: [companyId], references: [id])
  createdAt    DateTime   @default(now())

  @@unique([roleId, permissionId])
  @@index([companyId])
}

model UserRole {
  id        String   @id @default(uuid())
  userId    String
  roleId    String
  companyId String
  company   Company  @relation(fields: [companyId], references: [id])
  user      User     @relation(fields: [userId], references: [id])
  role      Role     @relation(fields: [roleId], references: [id])
  createdAt DateTime @default(now())

  @@unique([userId, roleId])
  @@index([companyId])
}

model ProductCategory {
  id          String    @id @default(uuid())
  companyId   String
  company     Company   @relation(fields: [companyId], references: [id])
  name        String
  description String?
  products    Product[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([companyId, name])
  @@index([companyId])
}

model Product {
  id                String              @id @default(uuid())
  companyId         String
  company           Company             @relation(fields: [companyId], references: [id])
  sku               String
  name              String
  description       String?
  categoryId        String?
  category          ProductCategory?    @relation(fields: [categoryId], references: [id])
  unitPrice         Decimal             @db.Decimal(12, 2)
  unitOfMeasure     String              @default("EA")
  isActive          Boolean             @default(true)
  customValues      CustomFieldValue[]
  stockMovements    StockMovement[]
  quoteLines        SalesQuoteLine[]
  salesOrderLines   SalesOrderLine[]
  purchaseLines     PurchaseOrderLine[]
  receiptLines      GoodsReceiptLine[]
  lowStockThreshold Decimal?            @db.Decimal(12, 2)
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt

  @@unique([companyId, sku])
  @@index([companyId])
}

model CustomFieldDefinition {
  id         String             @id @default(uuid())
  companyId  String
  company    Company            @relation(fields: [companyId], references: [id])
  entityType String
  fieldKey   String
  label      String
  fieldType  String
  isRequired Boolean            @default(false)
  createdAt  DateTime           @default(now())
  updatedAt  DateTime           @updatedAt
  values     CustomFieldValue[]

  @@unique([companyId, entityType, fieldKey])
  @@index([companyId])
}

model CustomFieldValue {
  id         String                @id @default(uuid())
  companyId  String
  company    Company               @relation(fields: [companyId], references: [id])
  recordId   String
  entityType String
  fieldId    String
  definition CustomFieldDefinition @relation(fields: [fieldId], references: [id])
  productId  String?
  product    Product?              @relation(fields: [productId], references: [id])
  value      String
  createdAt  DateTime              @default(now())
  updatedAt  DateTime              @updatedAt

  @@index([companyId])
  @@index([recordId])
  @@index([productId])
}

model Warehouse {
  id              String             @id @default(uuid())
  companyId       String
  company         Company            @relation(fields: [companyId], references: [id])
  name            String
  location        String?
  stock           StockMovement[]
  goodsReceipts   GoodsReceipt[]
  receiptLines    GoodsReceiptLine[]
  quoteLines      SalesQuoteLine[]
  salesOrderLines SalesOrderLine[]
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  @@unique([companyId, name])
  @@index([companyId])
}

model StockMovement {
  id           String            @id @default(uuid())
  companyId    String
  company      Company           @relation(fields: [companyId], references: [id])
  productId    String
  product      Product           @relation(fields: [productId], references: [id])
  warehouseId  String
  warehouse    Warehouse         @relation(fields: [warehouseId], references: [id])
  movementType StockMovementType
  quantity     Decimal           @db.Decimal(12, 2)
  reference    String?
  movementDate DateTime          @default(now())
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  @@index([companyId])
  @@index([productId, warehouseId])
  @@index([movementDate])
}

model Client {
  id          String       @id @default(uuid())
  companyId   String
  company     Company      @relation(fields: [companyId], references: [id])
  name        String
  email       String?
  phone       String?
  address     String?
  clientType  ClientType   @default(INSTITUTION)
  salesQuotes SalesQuote[]
  salesOrders SalesOrder[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@unique([companyId, name])
  @@index([companyId])
  @@index([companyId, clientType])
}

model Supplier {
  id             String          @id @default(uuid())
  companyId      String
  company        Company         @relation(fields: [companyId], references: [id])
  name           String
  email          String?
  phone          String?
  address        String?
  purchaseOrders PurchaseOrder[]
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  @@unique([companyId, name])
  @@index([companyId])
}

model SalesQuote {
  id             String              @id @default(uuid())
  companyId      String
  company        Company             @relation(fields: [companyId], references: [id])
  clientId       String
  client         Client              @relation(fields: [clientId], references: [id])
  quoteNumber    Int
  quoteDate      DateTime            @default(now())
  validUntil     DateTime?
  status         DocumentStatus      @default(DRAFT)
  subtotalAmount Decimal             @db.Decimal(14, 2)
  taxAmount      Decimal             @db.Decimal(14, 2)
  totalAmount    Decimal             @db.Decimal(14, 2)
  notes          String?
  lines          SalesQuoteLine[]
  taxLines       SalesQuoteTaxLine[]
  convertedOrder SalesOrder?         @relation("QuoteConversion")
  createdById    String?
  createdBy      User?               @relation(fields: [createdById], references: [id])
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt

  @@unique([companyId, quoteNumber])
  @@index([companyId])
  @@index([quoteDate])
}

model SalesQuoteLine {
  id           String     @id @default(uuid())
  salesQuoteId String
  salesQuote   SalesQuote @relation(fields: [salesQuoteId], references: [id])
  productId    String
  product      Product    @relation(fields: [productId], references: [id])
  warehouseId  String?
  warehouse    Warehouse? @relation(fields: [warehouseId], references: [id])
  description  String?
  quantity     Decimal    @db.Decimal(12, 2)
  unitPrice    Decimal    @db.Decimal(12, 2)
  lineTotal    Decimal    @db.Decimal(14, 2)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@index([warehouseId])
}

model SalesQuoteTaxLine {
  id           String     @id @default(uuid())
  salesQuoteId String
  salesQuote   SalesQuote @relation(fields: [salesQuoteId], references: [id])
  label        String
  taxCode      String?
  rate         Decimal    @db.Decimal(6, 3)
  baseAmount   Decimal    @db.Decimal(14, 2)
  taxAmount    Decimal    @db.Decimal(14, 2)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@index([salesQuoteId])
}

model SalesOrder {
  id             String              @id @default(uuid())
  companyId      String
  company        Company             @relation(fields: [companyId], references: [id])
  clientId       String
  client         Client              @relation(fields: [clientId], references: [id])
  salesQuoteId   String?             @unique
  salesQuote     SalesQuote?         @relation("QuoteConversion", fields: [salesQuoteId], references: [id])
  orderNumber    Int
  orderDate      DateTime            @default(now())
  status         DocumentStatus      @default(DRAFT)
  subtotalAmount Decimal             @db.Decimal(14, 2)
  taxAmount      Decimal             @db.Decimal(14, 2)
  totalAmount    Decimal             @db.Decimal(14, 2)
  notes          String?
  lines          SalesOrderLine[]
  taxLines       SalesOrderTaxLine[]
  createdById    String?
  createdBy      User?               @relation("OrderCreatedBy", fields: [createdById], references: [id])
  approvedById   String?
  approvedBy     User?               @relation("OrderApprovedBy", fields: [approvedById], references: [id])
  approvedAt     DateTime?
  confirmedById  String?
  confirmedBy    User?               @relation("OrderConfirmedBy", fields: [confirmedById], references: [id])
  confirmedAt    DateTime?
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt

  @@unique([companyId, orderNumber])
  @@index([companyId])
  @@index([companyId, status])
  @@index([orderDate])
}

model SalesOrderLine {
  id           String     @id @default(uuid())
  salesOrderId String
  salesOrder   SalesOrder @relation(fields: [salesOrderId], references: [id])
  productId    String
  product      Product    @relation(fields: [productId], references: [id])
  warehouseId  String
  warehouse    Warehouse  @relation(fields: [warehouseId], references: [id])
  description  String?
  quantity     Decimal    @db.Decimal(12, 2)
  unitPrice    Decimal    @db.Decimal(12, 2)
  lineTotal    Decimal    @db.Decimal(14, 2)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@index([warehouseId])
  @@index([productId])
}

model SalesOrderTaxLine {
  id           String     @id @default(uuid())
  salesOrderId String
  salesOrder   SalesOrder @relation(fields: [salesOrderId], references: [id])
  label        String
  taxCode      String?
  rate         Decimal    @db.Decimal(6, 3)
  baseAmount   Decimal    @db.Decimal(14, 2)
  taxAmount    Decimal    @db.Decimal(14, 2)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@index([salesOrderId])
}

model PurchaseOrder {
  id             String                 @id @default(uuid())
  companyId      String
  company        Company                @relation(fields: [companyId], references: [id])
  supplierId     String
  supplier       Supplier               @relation(fields: [supplierId], references: [id])
  poNumber       Int
  orderDate      DateTime               @default(now())
  expectedDate   DateTime?
  status         DocumentStatus         @default(DRAFT)
  subtotalAmount Decimal                @db.Decimal(14, 2)
  taxAmount      Decimal                @db.Decimal(14, 2)
  totalAmount    Decimal                @db.Decimal(14, 2)
  notes          String?
  lines          PurchaseOrderLine[]
  taxLines       PurchaseOrderTaxLine[]
  goodsReceipts  GoodsReceipt[]
  createdAt      DateTime               @default(now())
  updatedAt      DateTime               @updatedAt

  @@index([companyId])
  @@index([orderDate])
  @@index([companyId, poNumber])
}

model PurchaseOrderLine {
  id                String             @id @default(uuid())
  purchaseOrderId   String
  purchaseOrder     PurchaseOrder      @relation(fields: [purchaseOrderId], references: [id])
  productId         String
  product           Product            @relation(fields: [productId], references: [id])
  quantity          Decimal            @db.Decimal(12, 2)
  unitPrice         Decimal            @db.Decimal(12, 2)
  lineTotal         Decimal            @db.Decimal(14, 2)
  goodsReceiptLines GoodsReceiptLine[]
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
}

model PurchaseOrderTaxLine {
  id              String        @id @default(uuid())
  purchaseOrderId String
  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id])
  label           String
  taxCode         String?
  rate            Decimal       @db.Decimal(6, 3)
  baseAmount      Decimal       @db.Decimal(14, 2)
  taxAmount       Decimal       @db.Decimal(14, 2)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([purchaseOrderId])
}

model GoodsReceipt {
  id              String             @id @default(uuid())
  companyId       String
  company         Company            @relation(fields: [companyId], references: [id])
  purchaseOrderId String?
  purchaseOrder   PurchaseOrder?     @relation(fields: [purchaseOrderId], references: [id])
  warehouseId     String
  warehouse       Warehouse          @relation(fields: [warehouseId], references: [id])
  receiptNumber   Int
  receivedDate    DateTime           @default(now())
  status          DocumentStatus     @default(PARTIAL)
  notes           String?
  lines           GoodsReceiptLine[]
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  @@index([companyId])
  @@index([receivedDate])
  @@index([companyId, receiptNumber])
}

model GoodsReceiptLine {
  id                  String            @id @default(uuid())
  goodsReceiptId      String
  goodsReceipt        GoodsReceipt      @relation(fields: [goodsReceiptId], references: [id])
  purchaseOrderLineId String
  purchaseOrderLine   PurchaseOrderLine @relation(fields: [purchaseOrderLineId], references: [id])
  productId           String
  product             Product           @relation(fields: [productId], references: [id])
  quantity            Decimal           @db.Decimal(12, 2)
  unitPrice           Decimal           @db.Decimal(12, 2)
  lineTotal           Decimal           @db.Decimal(14, 2)
  warehouseId         String
  warehouse           Warehouse         @relation(fields: [warehouseId], references: [id])
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt
}

model AuditLog {
  id        String   @id @default(uuid())
  companyId String
  company   Company  @relation(fields: [companyId], references: [id])
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
  action    String
  entity    String
  entityId  String
  metadata  Json?
  createdAt DateTime @default(now())

  @@index([companyId])
  @@index([entity])
}
